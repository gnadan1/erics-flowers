  "inventory_item_schema": {
    "sku_id": {
      "type": "string",
      "required": true,
      "label": "SKU ID"
    },
    "category": {
      "type": "select",
      "required": true,
      "source": "categories.name",
      "label": "Category"
    },
    "subcategory": {
      "type": "dependent_select",
      "required": true,
      "depends_on": "category",
      "source": "categories.subcategories",
      "label": "Subcategory"
    },
    "variety_name": {
      "type": "string",
      "required": true,
      "label": "Variety / Item Name"
    },
    "display_name": {
      "type": "string",
      "required": false,
      "label": "Display Name"
    },
    "description": {
      "type": "textarea",
      "required": false,
      "label": "Description"
    },
    "vendor": {
      "type": "string",
      "required": false,
      "label": "Vendor"
    },
    "farm": {
      "type": "string",
      "required": false,
      "label": "Farm / Grower"
    },
    "country_of_origin": {
      "type": "string",
      "required": false,
      "label": "Country of Origin"
    },
    "color_family": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.color_family",
      "label": "Color Family"
    },
    "primary_color": {
      "type": "string",
      "required": false,
      "label": "Primary Color"
    },
    "secondary_color": {
      "type": "string",
      "required": false,
      "label": "Secondary Color"
    },
    "seasonality": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.seasonality",
      "label": "Seasonality"
    },
    "availability_status": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.availability_status",
      "label": "Availability"
    },
    "quality_grade": {
      "type": "number",
      "required": true,
      "min": 1,
      "max": 5,
      "label": "Quality Grade"
    },
    "floral_role": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.floral_role",
      "label": "Floral Role"
    },
    "stem_length": {
      "type": "number",
      "required": false,
      "label": "Stem Length"
    },
    "stem_length_unit": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.stem_length_unit",
      "default": "cm",
      "label": "Stem Length Unit"
    },
    "bloom_size": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.bloom_size",
      "label": "Bloom Size"
    },
    "stems_per_bunch": {
      "type": "number",
      "required": false,
      "label": "Stems per Bunch"
    },
    "fragrance_level": {
      "type": "number",
      "required": false,
      "min": 0,
      "max": 5,
      "label": "Fragrance Level"
    },
    "texture": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.texture",
      "label": "Texture"
    },
    "expected_vase_life_days": {
      "type": "number",
      "required": false,
      "label": "Expected Vase Life Days"
    },
    "requires_hydration": {
      "type": "boolean",
      "required": false,
      "default": true,
      "label": "Requires Hydration"
    },
    "storage_temperature": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.storage_temperature",
      "label": "Storage Temperature"
    },
    "pet_toxicity": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.pet_toxicity",
      "label": "Pet Toxicity"
    },
    "live_plant": {
      "type": "boolean",
      "required": false,
      "default": false,
      "label": "Live Plant"
    },
    "plant_pot_size": {
      "type": "string",
      "required": false,
      "label": "Plant Pot Size"
    },
    "plant_light_requirement": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.plant_light_requirement",
      "label": "Plant Light Requirement"
    },
    "plant_water_requirement": {
      "type": "select",
      "required": false,
      "options_ref": "dropdown_options.plant_water_requirement",
      "label": "Plant Water Requirement"
    },
    "unit_type": {
      "type": "select",
      "required": true,
      "options_ref": "dropdown_options.unit_type",
      "label": "Unit Type"
    },
    "quantity_on_hand": {
      "type": "number",
      "required": true,
      "min": 0,
      "label": "Quantity on Hand"
    },
    "quantity_reserved": {
      "type": "number",
      "required": false,
      "min": 0,
      "label": "Quantity Reserved"
    },
    "reorder_level": {
      "type": "number",
      "required": false,
      "min": 0,
      "label": "Reorder Level"
    },
    "cost_per_unit": {
      "type": "currency",
      "required": false,
      "label": "Cost per Unit"
    },
    "selling_price": {
      "type": "currency",
      "required": false,
      "label": "Selling Price"
    },
    "received_date": {
      "type": "date",
      "required": false,
      "label": "Received Date"
    },
    "expiration_date": {
      "type": "date",
      "required": false,
      "label": "Expiration / Pull Date"
    },
    "wedding_popularity": {
      "type": "number",
      "required": false,
      "min": 1,
      "max": 5,
      "label": "Wedding Popularity"
    },
    "event_popularity": {
      "type": "number",
      "required": false,
      "min": 1,
      "max": 5,
      "label": "Event Popularity"
    },
    "premium_item": {
      "type": "boolean",
      "required": false,
      "default": false,
      "label": "Premium Item"
    },
    "organic": {
      "type": "boolean",
      "required": false,
      "default": false,
      "label": "Organic"
    },
    "locally_grown": {
      "type": "boolean",
      "required": false,
      "default": false,
      "label": "Locally Grown"
    },
    "imported": {
      "type": "boolean",
      "required": false,
      "default": false,
      "label": "Imported"
    },
    "active": {
      "type": "boolean",
      "required": true,
      "default": true,
      "label": "Active"
    },
    "notes": {
      "type": "textarea",
      "required": false,
      "label": "Notes"
    }
  },
  "lovable_form_instructions": {
    "form_name": "Inventory Item Entry",
    "primary_table": "inventory_items",
    "dependent_dropdown_behavior": {
      "category_field": "category",
      "subcategory_field": "subcategory",
      "rule": "When the user selects a category, populate the subcategory dropdown with only the subcategories belonging to that category."
    },
    "recommended_pages": [
      "Inventory Item Entry",
      "Inventory List",
      "Inventory Detail",
      "Category/Subcategory Admin",
      "Vendor Admin"
    ],
    "validation_rules": [
      "category is required",
      "subcategory is required",
      "variety_name is required",
      "quality_grade must be between 1 and 5",
      "quantity_on_hand must be zero or greater",
      "unit_type is required",
      "sku_id must be unique"
    ],
    "recommended_search_filters": [
      "category",
      "subcategory",
      "color_family",
      "seasonality",
      "availability_status",
      "quality_grade",
      "vendor",
      "active",
      "premium_item",
      "live_plant"
    ]
  },
